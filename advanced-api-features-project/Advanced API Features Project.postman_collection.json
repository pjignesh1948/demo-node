              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Protected route requiring auth plus role('super_admin'). The current route returns a static success message and does not actually delete from a database."
          },
          "response": []
