              "path": [
                "users"
              ]
            },
            "description": "Protected route. Requires Authorization: Bearer {{token}}. Returns a demo payload showing pagination, filtering, sorting, and search query handling."
          },
          "response": []
        },
        {
          "name": "Get Users - Pagination, Filter, Search, Sort",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users?page=2&limit=5&role=user&search=gov&sortBy=createdAt&order=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "2"
                },
                {
                  "key": "limit",
                  "value": "5"
                },
                {
                  "key": "role",
                  "value": "user"
                },
                {
                  "key": "search",
                  "value": "gov"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt"
                },
                {
                  "key": "order",
                  "value": "desc"
                }
              ]
            },
            "description": "Demonstrates how the controller builds page, limit, skip, role filter, regex search, and sort order from the query string."
          },
          "response": []
        },
        {
          "name": "Delete User by ID",
          "request": {
